# -*- coding: utf-8 -*-
"""
Quantum-Augmented STPP Dengue Forecasting — Main Pipeline
========================================================

This notebook implements the complete pipeline for:
1. Data loading & preprocessing
2. Spatial statistics (K-function, L-function, Moran's I)
3. Baseline models (CNN-LSTM, Hawkes, NEST)
4. SOP augmentation
5. Quantum augmentation (QBM, QGAN)
6. Integrated training & evaluation

Author: Research Pipeline
Date: 2026-05-30
"""

# ─── Imports ────────────────────────────────────────────────────────────────
import sys, os
sys.path.insert(0, os.path.dirname(os.path.dirname(os.path.abspath("."))))

import numpy as np
import pandas as pd
import matplotlib
matplotlib.use("Agg")
import matplotlib.pyplot as plt
import seaborn as sns
from pathlib import Path
import warnings
warnings.filterwarnings("ignore")

import torch

from src.data.loader import (
    load_raw_data, build_stpp_events, create_spatial_grid,
    temporal_split, compute_country_summary
)
from src.data.coordinates import get_all_coords
from src.evaluation.spatial_stats import (
    compute_k_function, compute_l_function, compute_pc_function,
    spatial_autocorrelation, temporal_autocorrelation,
    seasonal_decomposition, zero_inflation_ratio, compute_overdispersion
)
from src.evaluation.metrics import (
    compute_forecasting_metrics, compute_classification_metrics,
    compute_point_process_metrics, comprehensive_evaluation
)
from src.models.hawkes import MultiDimensionalHawkes
from src.models.nest import NESTModel, prepare_nest_training_data, train_nest
from src.models.cnn_lstm import SpatioTemporalCNN, create_sequences, train_cnn_lstm
from src.augmentation.sop import (
    sop_augment, sop_augment_spatial_clusters, validate_sop_preservation,
    compute_k_function_empirical, compute_l_function_from_k
)
from src.augmentation.quantum_augment import (
    QuantumBornMachine, HybridStyleQGAN, QuantumAugmentationPipeline
)

# ─── Setup ─────────────────────────────────────────────────────────────────
OUTPUT_DIR = Path("outputs")
OUTPUT_DIR.mkdir(exist_ok=True)
DATA_DIR = Path("../dengue_dataset")
SEED = 42
np.random.seed(SEED)
torch.manual_seed(SEED)

DEVICE = "cuda" if torch.cuda.is_available() else "cpu"
print(f"Device: {DEVICE}")
print(f"PyTorch: {torch.__version__}")

# ════════════════════════════════════════════════════════════════════════════
# PHASE 1: DATA LOADING & PREPROCESSING
# ════════════════════════════════════════════════════════════════════════════
print("\n" + "="*70)
print("PHASE 1: DATA LOADING & PREPROCESSING")
print("="*70)

spatial_df, long_df, pivot_df = load_raw_data(DATA_DIR)
print(f"Raw data loaded:")
print(f"  Spatial: {spatial_df.shape}")
print(f"  Long format: {long_df.shape}")
print(f"  Pivot: {pivot_df.shape}")

events_df = build_stpp_events(
    long_df,
    min_cases=0,
    remove_sparse=True,
    zero_threshold=0.95
)
print(f"\nSTPP events created: {events_df.shape}")
print(f"  Date range: {events_df['timestamp'].min()} to {events_df['timestamp'].max()}")
print(f"  Countries: {events_df['country'].nunique()}")
print(f"  Regions: {events_df['region'].nunique()}")
print(f"  Total cases: {events_df['case_count'].sum():,.0f}")

coords = get_all_coords()
matched = events_df["region"].apply(lambda r: r in coords).mean()
print(f"  Coordinate match rate: {matched:.1%}")

# Spatial grid for CNN
grid, grid_lats, grid_lons = create_spatial_grid(events_df, grid_size=16)
print(f"  Spatial grid: {grid.shape}")

# Temporal split
train_events, val_events, test_events = temporal_split(
    events_df, train_ratio=0.70, val_ratio=0.15, test_ratio=0.15
)
print(f"\nTemporal split:")
print(f"  Train: {len(train_events):,} events ({train_events['timestamp'].min()} - {train_events['timestamp'].max()})")
print(f"  Val:   {len(val_events):,} events ({val_events['timestamp'].min()} - {val_events['timestamp'].max()})")
print(f"  Test:  {len(test_events):,} events ({test_events['timestamp'].min()} - {test_events['timestamp'].max()})")

country_summary = compute_country_summary(events_df)
print(f"\nCountry summary saved.")
country_summary.to_csv(OUTPUT_DIR / "country_summary.csv", index=False)

# ════════════════════════════════════════════════════════════════════════════
# PHASE 2: EXTENDED EXPLORATORY DATA ANALYSIS
# ════════════════════════════════════════════════════════════════════════════
print("\n" + "="*70)
print("PHASE 2: EXTENDED EXPLORATORY DATA ANALYSIS")
print("="*70)

# Zero-inflation analysis
for country in ["VIET NAM", "THAILAND", "INDONESIA", "MALAYSIA"]:
    sub = events_df[events_df["country"] == country]
    zi = zero_inflation_ratio(sub["case_count"].values)
    od = compute_overdispersion(sub["case_count"].values)
    print(f"  {country}: Zero-inflation={zi:.1%}, Overdispersion={od:.1f}")

# Spatial autocorrelation per country
print("\n  Spatial autocorrelation (Moran's I) by country:")
for country in ["VIET NAM", "THAILAND", "INDONESIA"]:
    sub = events_df[events_df["country"] == country]
    if len(sub) > 20:
        I, p = spatial_autocorrelation(
            sub["lat"].values, sub["lon"].values,
            sub["case_count"].values
        )
        print(f"  {country}: I={I:.4f}, p={p:.4f} {'***' if p<0.001 else '**' if p<0.01 else '*' if p<0.05 else ''}")

# K-function and L-function for each country
print("\n  K-function and L-function (radii=[0.5, 1, 2, 5] degrees):")
K_by_country = {}
L_by_country = {}
radii = np.array([0.5, 1.0, 2.0, 5.0])

fig, axes = plt.subplots(2, 4, figsize=(20, 10))
countries = ["VIET NAM", "THAILAND", "INDONESIA", "MALAYSIA",
             "CAMBODIA", "SINGAPORE", "PHILIPPINES", "LAO PEOPLE'S DEMOCRATIC REPUBLIC"]
countries = [c for c in countries if c in events_df["country"].unique()]

for idx, country in enumerate(countries[:len(countries)]):
    sub = events_df[events_df["country"] == country]
    ax = axes.flat[idx]

    if len(sub) > 20:
        lats = sub["lat"].values
        lons = sub["lon"].values

        K, _, _, _ = compute_k_function_empirical(
            lats, lons, radii, n_permutations=19, confidence_level=0.95
        )
        L = compute_l_function_from_k(K, radii) if K is not None else None

        K_by_country[country] = K
        L_by_country[country] = L

        ax.plot(radii, L, "o-", color="steelblue", label="L(r)")
        ax.axhline(0, color="gray", linestyle="--", alpha=0.5)
        ax.set_title(f"{country[:15]}")
        ax.set_xlabel("r (degrees)")
        ax.set_ylabel("L(r)")
        ax.legend(fontsize=8)

        if L is not None and np.mean(L) > 0:
            interpretation = "Clustering"
        elif L is not None and np.mean(L) < 0:
            interpretation = "Regularity"
        else:
            interpretation = "CSR-like"
        print(f"  {country}: L(r) mean={np.mean(L):.3f} → {interpretation}")

plt.tight_layout()
plt.savefig(OUTPUT_DIR / "eda_k_l_functions.png", dpi=150, bbox_inches="tight")
plt.close()
print(f"  K/L function plots saved to {OUTPUT_DIR / 'eda_k_l_functions.png'}")

# Seasonal decomposition
print("\n  Seasonal decomposition for Vietnam:")
vn = events_df[events_df["country"] == "VIET NAM"]
vn_monthly = vn.groupby(vn["timestamp"].dt.to_period("M"))["case_count"].sum()
if len(vn_monthly) > 24:
    trend, seasonal, residual = seasonal_decomposition(vn_monthly.values, period=12)
    print(f"    Peak months: {np.argsort(seasonal)[-3:][::-1]+1}")
    print(f"    Trough months: {np.argsort(seasonal)[:3]+1}")

# Monthly patterns across all countries
fig, ax = plt.subplots(figsize=(14, 6))
monthly_by_country = events_df.groupby(["country", "month"])["case_count"].sum().unstack(level=0)
monthly_by_country.plot(ax=ax, linewidth=2)
ax.set_xlabel("Month")
ax.set_ylabel("Total Cases")
ax.set_title("Monthly Dengue Cases by Country (1993-2022)")
ax.legend(bbox_to_anchor=(1.02, 1), loc="upper left", fontsize=8)
plt.tight_layout()
plt.savefig(OUTPUT_DIR / "eda_monthly_patterns.png", dpi=150, bbox_inches="tight")
plt.close()

# Yearly trends
fig, ax = plt.subplots(figsize=(14, 6))
yearly = events_df.groupby(["country", "year"])["case_count"].sum().unstack(level=0)
yearly.plot(ax=ax, linewidth=2)
ax.set_xlabel("Year")
ax.set_ylabel("Total Cases")
ax.set_title("Yearly Dengue Cases by Country (1993-2022)")
ax.legend(bbox_to_anchor=(1.02, 1), loc="upper left", fontsize=8)
plt.tight_layout()
plt.savefig(OUTPUT_DIR / "eda_yearly_trends.png", dpi=150, bbox_inches="tight")
plt.close()
print("  Monthly and yearly trend plots saved.")

# Geographic scatter
fig, ax = plt.subplots(figsize=(14, 10))
total_by_region = events_df.groupby(["lat", "lon"])["case_count"].sum().reset_index()
scatter = ax.scatter(
    total_by_region["lon"], total_by_region["lat"],
    c=np.log1p(total_by_region["case_count"]),
    cmap="YlOrRd", alpha=0.6, s=30, edgecolors="none"
)
plt.colorbar(scatter, label="log(1 + total cases)")
ax.set_xlabel("Longitude")
ax.set_ylabel("Latitude")
ax.set_title("Geographic Distribution of Dengue Cases (SE Asia, 1993-2022)")
ax.set_xlim(90, 145)
ax.set_ylim(-12, 25)
plt.tight_layout()
plt.savefig(OUTPUT_DIR / "eda_geographic_distribution.png", dpi=150, bbox_inches="tight")
plt.close()
print("  Geographic distribution plot saved.")

# ════════════════════════════════════════════════════════════════════════════
# PHASE 3: BASELINE MODELS (NO AUGMENTATION)
# ════════════════════════════════════════════════════════════════════════════
print("\n" + "="*70)
print("PHASE 3: BASELINE MODELS (NO AUGMENTATION)")
print("="*70)

# --- 3a. Hawkes Process ---
print("\n[3a] Training Hawkes Process...")
hawkes_events = train_events[train_events["case_count"] > 0].copy()
if len(hawkes_events) > 50:
    hawkes_events["t_month"] = (
        (hawkes_events["timestamp"] - hawkes_events["timestamp"].min())
    ).dt.days / 30.0

    unique_regions = hawkes_events["country"].unique()
    region_to_idx = {r: i for i, r in enumerate(unique_regions)}
    hawkes_events["region_idx"] = hawkes_events["country"].map(region_to_idx)

    hawkes_model = MultiDimensionalHawkes(
        n_regions=len(unique_regions),
        spatial_decay=0.05,
        temporal_decay=0.3,
        learnable_spatial_decay=True,
    )

    hawkes_model.fit(
        hawkes_events["t_month"].values,
        hawkes_events["region_idx"].values,
        hawkes_events["case_count"].values,
        max_iter=200,
        verbose=False,
    )
    print(f"  Hawkes trained. Baseline intensities: {hawkes_model.mu[:3]}")
    print(f"  Excitation matrix diagonal: {np.diag(hawkes_model.alpha)[:3]}")
    hawkes_trained = hawkes_model
else:
    hawkes_trained = None
    print("  Insufficient data for Hawkes training.")

# --- 3b. CNN-LSTM ---
print("\n[3b] Training CNN-LSTM...")
try:
    train_grid, _, _ = create_spatial_grid(train_events, grid_size=16)
    val_grid, _, _ = create_spatial_grid(val_events, grid_size=16)

    X_train, y_train = create_sequences(train_grid, seq_len=12, forecast_horizon=1)
    X_val, y_val = create_sequences(val_grid, seq_len=12, forecast_horizon=1)

    if len(X_train) > 50 and len(X_val) > 10:
        train_dataset = torch.utils.data.TensorDataset(
            torch.FloatTensor(X_train), torch.FloatTensor(y_train)
        )
        val_dataset = torch.utils.data.TensorDataset(
            torch.FloatTensor(X_val), torch.FloatTensor(y_val)
        )
        train_loader = torch.utils.data.DataLoader(train_dataset, batch_size=32, shuffle=True)
        val_loader = torch.utils.data.DataLoader(val_dataset, batch_size=32)

        cnn_lstm_model = SpatioTemporalCNN(
            input_channels=1,
            conv_channels=[32, 64],
            lstm_hidden=64,
            lstm_layers=2,
            dropout=0.3,
            grid_size=16,
            forecast_horizon=1,
        )

        cnn_lstm_model = train_cnn_lstm(
            cnn_lstm_model, train_loader, val_loader,
            epochs=50, lr=1e-3, device=DEVICE,
            patience=10, seed=SEED, verbose=True
        )
        print("  CNN-LSTM trained successfully.")

        with torch.no_grad():
            X_val_t = torch.FloatTensor(X_val).to(DEVICE)
            y_pred_cnn = cnn_lstm_model(X_val_t).cpu().numpy().flatten()
            y_true_cnn = y_val.flatten()

            cnn_metrics = compute_forecasting_metrics(y_true_cnn, y_pred_cnn)
            print(f"  CNN-LSTM Results: RMSE={cnn_metrics['RMSE']:.2f}, MAE={cnn_metrics['MAE']:.2f}, R2={cnn_metrics['R2']:.3f}")
    else:
        cnn_lstm_model = None
        cnn_metrics = {}
        print("  Insufficient data for CNN-LSTM.")
except Exception as e:
    cnn_lstm_model = None
    cnn_metrics = {}
    print(f"  CNN-LSTM failed: {e}")

# Store baseline results
baseline_results = {
    "no_augmentation": {
        "hawkes": {"fitted": hawkes_trained is not None},
        "cnn_lstm": cnn_metrics,
    }
}

# ════════════════════════════════════════════════════════════════════════════
# PHASE 4: SOP AUGMENTATION
# ════════════════════════════════════════════════════════════════════════════
print("\n" + "="*70)
print("PHASE 4: SOP AUGMENTATION")
print("="*70)

print("\n[4a] Running SOP augmentation (cluster-based)...")
sop_augmented_dfs = sop_augment_spatial_clusters(
    train_events,
    n_augment=2,
    n_clusters=5,
    window_months=3,
    preserve_case_distribution=True,
    random_state=SEED,
)
print(f"  Generated {len(sop_augmented_dfs)} SOP-augmented datasets")

# Validate preservation
print("\n[4b] Validating SOP preservation...")
sop_validation = validate_sop_preservation(
    train_events,
    sop_augmented_dfs,
    radii=radii,
    n_permutations=19,
)

if sop_validation.get("k_function_mae"):
    valid_k = [v for v in sop_validation["k_function_mae"] if v is not None]
    valid_l = [v for v in sop_validation["l_function_mae"] if v is not None]
    if valid_k:
        print(f"  K-function MAE: {np.mean(valid_k):.4f} ± {np.std(valid_k):.4f}")
    if valid_l:
        print(f"  L-function MAE: {np.mean(valid_l):.4f} ± {np.std(valid_l):.4f}")
    if sop_validation.get("case_dist_wasserstein"):
        wds = [v for v in sop_validation["case_dist_wasserstein"] if v is not None]
        if wds:
            print(f"  Case dist Wasserstein: {np.mean(wds):.2f} ± {np.std(wds):.2f}")

# Combine with original
sop_combined = pd.concat([train_events] + sop_augmented_dfs, ignore_index=True)
print(f"  Combined dataset: {len(sop_combined):,} events (original {len(train_events):,} + {len(sop_combined)-len(train_events):,} augmented)")

# Retrain with SOP augmentation
print("\n[4c] Retraining CNN-LSTM with SOP augmentation...")
try:
    sop_grid, _, _ = create_spatial_grid(sop_combined, grid_size=16)
    X_sop, y_sop = create_sequences(sop_grid, seq_len=12, forecast_horizon=1)

    if len(X_sop) > 50 and len(X_val) > 10:
        sop_dataset = torch.utils.data.TensorDataset(
            torch.FloatTensor(X_sop), torch.FloatTensor(y_sop)
        )
        sop_loader = torch.utils.data.DataLoader(sop_dataset, batch_size=32, shuffle=True)

        cnn_lstm_sop = SpatioTemporalCNN(
            input_channels=1, conv_channels=[32, 64],
            lstm_hidden=64, lstm_layers=2, dropout=0.3,
            grid_size=16, forecast_horizon=1,
        )

        cnn_lstm_sop = train_cnn_lstm(
            cnn_lstm_sop, sop_loader, val_loader,
            epochs=50, lr=1e-3, device=DEVICE,
            patience=10, seed=SEED, verbose=True
        )

        with torch.no_grad():
            X_val_t = torch.FloatTensor(X_val).to(DEVICE)
            y_pred_sop = cnn_lstm_sop(X_val_t).cpu().numpy().flatten()
            sop_cnn_metrics = compute_forecasting_metrics(y_true_cnn, y_pred_sop)
            print(f"  SOP-CNN-LSTM Results: RMSE={sop_cnn_metrics['RMSE']:.2f}, MAE={sop_cnn_metrics['MAE']:.2f}, R2={sop_cnn_metrics['R2']:.3f}")
    else:
        sop_cnn_metrics = {}
except Exception as e:
    sop_cnn_metrics = {}
    print(f"  SOP retraining failed: {e}")

baseline_results["sop_augmentation"] = {"cnn_lstm": sop_cnn_metrics}

# ════════════════════════════════════════════════════════════════════════════
# PHASE 5: QUANTUM AUGMENTATION
# ════════════════════════════════════════════════════════════════════════════
print("\n" + "="*70)
print("PHASE 5: QUANTUM AUGMENTATION")
print("="*70)

# --- 5a. Quantum Born Machine ---
print("\n[5a] Training Quantum Born Machine...")
try:
    qbm_pipeline = QuantumAugmentationPipeline(
        model_type="qbm",
        n_qubits=8,
        n_layers=4,
        augmentation_ratio=2,
        seed=SEED,
    )
    qbm_pipeline.fit(train_events, epochs=200, verbose=True)
    print("  QBM training complete.")
    qbm_fitted = True
except Exception as e:
    qbm_pipeline = None
    qbm_fitted = False
    print(f"  QBM failed: {e}")

# --- 5b. Hybrid Style-Based QGAN ---
print("\n[5b] Training Hybrid Style-Based QGAN...")
try:
    qgan_pipeline = QuantumAugmentationPipeline(
        model_type="qgan",
        n_qubits=8,
        n_layers=4,
        latent_dim=16,
        augmentation_ratio=3,
        seed=SEED,
    )
    qgan_pipeline.fit(train_events, epochs=200, verbose=True)
    print("  QGAN training complete.")
    qgan_fitted = True
except Exception as e:
    qgan_pipeline = None
    qgan_fitted = False
    print(f"  QGAN failed: {e}")

# --- 5c. Generate synthetic events ---
print("\n[5c] Generating synthetic events...")
synthetic_events_list = []

if qbm_fitted and qbm_pipeline is not None:
    try:
        qbm_samples = qbm_pipeline.generate(n_samples=len(train_events) * 2)
        print(f"  QBM generated: {len(qbm_samples)} samples")
    except Exception as e:
        print(f"  QBM generation failed: {e}")
        qbm_samples = np.array([])

if qgan_fitted and qgan_pipeline is not None:
    try:
        qgan_samples = qgan_pipeline.generate(n_samples=len(train_events) * 3)
        print(f"  QGAN generated: {len(qgan_samples)} samples")

        if len(qgan_samples) > 0:
            for i, sample in enumerate(qgan_samples):
                case_val = max(0, int(sample[0] * 100)) if len(sample) > 0 else 0
                lat_val = sample[1] if len(sample) > 1 else 10.0
                lon_val = sample[2] if len(sample) > 2 else 105.0

                base_ts = train_events["timestamp"].min()
                ts_offset = pd.Timedelta(days=i % 365)
                synth_event = pd.DataFrame([{
                    "event_id": train_events["event_id"].max() + i + 1,
                    "lat": 10.0 + lat_val * 15,
                    "lon": 95.0 + lon_val * 50,
                    "timestamp": base_ts + ts_offset,
                    "case_count": case_val,
                    "region": "SYNTHETIC",
                    "country": "SYNTHETIC",
                    "year": (base_ts + ts_offset).year,
                    "month": (base_ts + ts_offset).month,
                    "augmented": True,
                    "aug_method": "qgan",
                }])
                synthetic_events_list.append(synth_event)
    except Exception as e:
        print(f"  QGAN generation failed: {e}")

if synthetic_events_list:
    synthetic_df = pd.concat(synthetic_events_list, ignore_index=True)
    quantum_combined = pd.concat([train_events, synthetic_df], ignore_index=True)
    print(f"  Quantum-combined dataset: {len(quantum_combined):,} events")
else:
    quantum_combined = train_events.copy()
    print("  No synthetic events generated; using original data.")

# Retrain with quantum augmentation
print("\n[5d] Retraining CNN-LSTM with quantum augmentation...")
try:
    quantum_grid, _, _ = create_spatial_grid(quantum_combined, grid_size=16)
    X_quantum, y_quantum = create_sequences(quantum_grid, seq_len=12, forecast_horizon=1)

    if len(X_quantum) > 50 and len(X_val) > 10:
        quantum_dataset = torch.utils.data.TensorDataset(
            torch.FloatTensor(X_quantum), torch.FloatTensor(y_quantum)
        )
        quantum_loader = torch.utils.data.DataLoader(quantum_dataset, batch_size=32, shuffle=True)

        cnn_lstm_quantum = SpatioTemporalCNN(
            input_channels=1, conv_channels=[32, 64],
            lstm_hidden=64, lstm_layers=2, dropout=0.3,
            grid_size=16, forecast_horizon=1,
        )

        cnn_lstm_quantum = train_cnn_lstm(
            cnn_lstm_quantum, quantum_loader, val_loader,
            epochs=50, lr=1e-3, device=DEVICE,
            patience=10, seed=SEED, verbose=True
        )

        with torch.no_grad():
            X_val_t = torch.FloatTensor(X_val).to(DEVICE)
            y_pred_q = cnn_lstm_quantum(X_val_t).cpu().numpy().flatten()
            quantum_cnn_metrics = compute_forecasting_metrics(y_true_cnn, y_pred_q)
            print(f"  Quantum-CNN-LSTM Results: RMSE={quantum_cnn_metrics['RMSE']:.2f}, MAE={quantum_cnn_metrics['MAE']:.2f}, R2={quantum_cnn_metrics['R2']:.3f}")
    else:
        quantum_cnn_metrics = {}
except Exception as e:
    quantum_cnn_metrics = {}
    print(f"  Quantum retraining failed: {e}")

baseline_results["quantum_augmentation"] = {"cnn_lstm": quantum_cnn_metrics}

# ════════════════════════════════════════════════════════════════════════════
# PHASE 6: COMPREHENSIVE EVALUATION
# ════════════════════════════════════════════════════════════════════════════
print("\n" + "="*70)
print("PHASE 6: COMPREHENSIVE EVALUATION")
print("="*70)

print("\n┌─────────────────────┬──────────┬──────────┬──────────┐")
print("│ Method              │ RMSE     │ MAE      │ R2       │")
print("├─────────────────────┼──────────┼──────────┼──────────┤")

all_results = {}
for method, results in baseline_results.items():
    cnn_m = results.get("cnn_lstm", {})
    rmse = cnn_m.get("RMSE", float("nan"))
    mae = cnn_m.get("MAE", float("nan"))
    r2 = cnn_m.get("R2", float("nan"))
    print(f"│ {method:<19} │ {rmse:>8.2f} │ {mae:>8.2f} │ {r2:>8.3f} │")
    all_results[method] = cnn_m

print("└─────────────────────┴──────────┴──────────┴──────────┘")

# Test set evaluation
print("\nTest set evaluation:")
if cnn_lstm_model is not None:
    test_grid, _, _ = create_spatial_grid(test_events, grid_size=16)
    X_test, y_test = create_sequences(test_grid, seq_len=12, forecast_horizon=1)
    if len(X_test) > 10:
        with torch.no_grad():
            X_test_t = torch.FloatTensor(X_test).to(DEVICE)
            y_pred_test = cnn_lstm_model(X_test_t).cpu().numpy().flatten()
            test_metrics = compute_forecasting_metrics(y_test.flatten(), y_pred_test)
            print(f"  No aug (test): RMSE={test_metrics['RMSE']:.2f}, MAE={test_metrics['MAE']:.2f}")

if cnn_lstm_sop is not None and len(X_test) > 10:
    with torch.no_grad():
        y_pred_sop_test = cnn_lstm_sop(X_test_t).cpu().numpy().flatten()
        sop_test_metrics = compute_forecasting_metrics(y_test.flatten(), y_pred_sop_test)
        print(f"  SOP aug (test): RMSE={sop_test_metrics['RMSE']:.2f}, MAE={sop_test_metrics['MAE']:.2f}")

if cnn_lstm_quantum is not None and len(X_test) > 10:
    with torch.no_grad():
        y_pred_q_test = cnn_lstm_quantum(X_test_t).cpu().numpy().flatten()
        q_test_metrics = compute_forecasting_metrics(y_test.flatten(), y_pred_q_test)
        print(f"  Quantum aug (test): RMSE={q_test_metrics['RMSE']:.2f}, MAE={q_test_metrics['MAE']:.2f}")

# Point process quality comparison
print("\nPoint Process Quality (K-function):")
valid_methods = []
if len(train_events) > 20:
    lats_o, lons_o = train_events["lat"].values, train_events["lon"].values
    K_o, _, _, _ = compute_k_function_empirical(lats_o, lons_o, radii, n_permutations=9)
    L_o = compute_l_function_from_k(K_o, radii)

    valid_methods.append(("original", train_events))

    if sop_augmented_dfs:
        for i, sop_df in enumerate(sop_augmented_dfs[:1]):
            valid_methods.append((f"sop_{i}", sop_df))

    if synthetic_events_list:
        valid_methods.append(("quantum", synthetic_df))

    fig, axes = plt.subplots(1, 2, figsize=(14, 5))

    for label, df in valid_methods:
        if len(df) > 20:
            lats, lons = df["lat"].values, df["lon"].values
            K, _, _, _ = compute_k_function_empirical(lats, lons, radii, n_permutations=9)
            L = compute_l_function_from_k(K, radii) if K is not None else None
            if L is not None:
                axes[0].plot(radii, L, "o-", label=label)
                axes[1].semilogy(radii, np.abs(L) + 1e-3, "o-", label=label)

    axes[0].axhline(0, color="gray", linestyle="--", alpha=0.5)
    axes[0].set_xlabel("r (degrees)")
    axes[0].set_ylabel("L(r)")
    axes[0].set_title("L-function Comparison")
    axes[0].legend()
    axes[1].set_xlabel("r (degrees)")
    axes[1].set_ylabel("|L(r)| (log scale)")
    axes[1].set_title("L-function Magnitude (log)")
    axes[1].legend()
    plt.tight_layout()
    plt.savefig(OUTPUT_DIR / "evaluation_k_function_comparison.png", dpi=150, bbox_inches="tight")
    plt.close()
    print(f"  K-function comparison saved.")

# Final results summary
print("\n" + "="*70)
print("FINAL RESULTS SUMMARY")
print("="*70)
print(f"\nDataset: {len(events_df):,} events across {events_df['country'].nunique()} countries")
print(f"Period: {events_df['timestamp'].min()} to {events_df['timestamp'].max()}")
print(f"Total cases: {events_df['case_count'].sum():,.0f}")
print(f"\nSpatial grid: {grid.shape}")
print(f"Train/Val/Test split: {len(train_events):,}/{len(val_events):,}/{len(test_events):,} events")

if all_results:
    print("\nForecasting Results (Validation Set):")
    best_method = min(
        [m for m in all_results if all_results[m].get("RMSE") and not np.isnan(all_results[m]["RMSE"])],
        key=lambda m: all_results[m]["RMSE"]
    )
    for method, metrics in all_results.items():
        rmse = metrics.get("RMSE", float("nan"))
        mae = metrics.get("MAE", float("nan"))
        r2 = metrics.get("R2", float("nan"))
        marker = " ← BEST" if method == best_method else ""
        print(f"  {method:<25} RMSE={rmse:>8.2f}  MAE={mae:>8.2f}  R2={r2:>8.3f}{marker}")

print("\n  Quantum augmentation methods:")
print(f"    QBM: {'Fitted' if qbm_fitted else 'Failed'}")
print(f"    QGAN: {'Fitted' if qgan_fitted else 'Failed'}")
print(f"    Synthetic events generated: {len(synthetic_events_list)}")

